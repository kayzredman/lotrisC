# Lotris on-prem environment template
# Copy: cp deploy/.env.onprem.example deploy/.env.onprem
# Use:  docker compose -f docker/docker-compose.onprem.yml --env-file deploy/.env.onprem up -d --build

# ── Public URL (browser-facing, through nginx proxy) ─────────────────────────
PUBLIC_BASE_URL=http://localhost
LOTRIS_HTTP_PORT=80

# ── Database ─────────────────────────────────────────────────────────────────
MSSQL_SA_PASSWORD=Lotris@OnPrem2024!
MSSQL_DATABASE=lotris
MSSQL_PID=Developer
DATABASE_APPLY_LEGACY_MIGRATIONS=true

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=lotris_onprem_redis

# ── API security ─────────────────────────────────────────────────────────────
# Must be at least 32 characters
JWT_SECRET=change-me-on-prem-use-at-least-32-characters-long-secret

# ── CORS (comma-separated origins) ───────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost

# ── Web auth providers (comma-separated: identity,entra,ldap) ────────────────
NEXT_PUBLIC_AUTH_PROVIDERS=identity

# ── OpenAPI / Scalar (set false in hardened production) ──────────────────────
OPENAPI_ENABLED=true
OPENAPI_UI_ENABLED=true

# ── Analytics job bounds (sysadmin can tune further in ops console) ──────────
ANALYTICS_MIN_ROLLUP_MINUTES=2
ANALYTICS_MAX_ROLLUP_MINUTES=60
ANALYTICS_MIN_CACHE_TTL=10
ANALYTICS_MAX_CACHE_TTL=300
ANALYTICS_MAX_DAILY_BATCH=4
ANALYTICS_MANUAL_COOLDOWN=60

# ── Bootstrap (Track A — automated install) ──────────────────────────────────
# Run after stack is up:
#   docker compose -f docker/docker-compose.onprem.yml --env-file deploy/.env.onprem --profile bootstrap run --rm bootstrap
LOTRIS_SKIP_ONBOARDING=true
LOTRIS_ADMIN_EMAIL=admin@lotris.local
LOTRIS_ADMIN_PASSWORD=ChangeMe1!Lotris
LOTRIS_ADMIN_NAME=Lotris Admin
LOTRIS_TENANT_NAME=Lotris
LOTRIS_TENANT_SLUG=lotris
LOTRIS_DEFAULT_TEAM=General Support

# Track B (demo / eval): set LOTRIS_SKIP_ONBOARDING=false — first admin sees wizard
