# Lotris — Staging Environment Variables
# Copy this file and fill in real values for each platform.
# ⚠️  Never commit a filled-in copy — this template only.
#
# HOW VALUES ARE DISTRIBUTED:
#   Railway (API service)     → all vars below
#   Railway (Workers service) → same vars as API (copy them)
#   Vercel (Web)              → NEXT_PUBLIC_* + CLERK_SECRET_KEY only
#
# Full setup guide: docs/STAGING.md

# ── Node ───────────────────────────────────────────────────────────────────
NODE_ENV=production

# ── Databases ──────────────────────────────────────────────────────────────

# MSSQL — Railway Docker service (use Railway internal hostname inside Railway)
# Internal (API/Workers on Railway): sqlserver://sa:<pw>@mssql.railway.internal:1433;database=lotris;trustServerCertificate=true
# External (migrations from local):  sqlserver://sa:<pw>@<public-host>:<port>;database=lotris;trustServerCertificate=true
DATABASE_URL_MSSQL=sqlserver://sa:CHANGE_ME@mssql.railway.internal:1433;database=lotris;trustServerCertificate=true

# PostgreSQL — Neon free tier
# Get from: neon.tech → Project → Connection Details → copy "Pooled connection"
DATABASE_URL_POSTGRES=postgresql://lotris:CHANGE_ME@ep-CHANGE_ME.us-east-2.aws.neon.tech/lotris_analytics?sslmode=require

# Redis — Upstash free tier
# Get from: upstash.com → Database → Details → copy REDIS_URL (must start with rediss://)
REDIS_URL=rediss://default:CHANGE_ME@CHANGE_ME.upstash.io:6379

# ── Auth ───────────────────────────────────────────────────────────────────

# Clerk — use your existing dev/staging instance keys
# Get from: dashboard.clerk.com → API Keys
CLERK_SECRET_KEY=sk_test_CHANGE_ME
CLERK_WEBHOOK_SECRET=whsec_CHANGE_ME

# ── Internal JWT ───────────────────────────────────────────────────────────
# Must be ≥ 32 characters. Generate with: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_CHANGE_ME_CHANGE_ME_32chars

# ── API ────────────────────────────────────────────────────────────────────
API_PORT=4000

# ── URLs ───────────────────────────────────────────────────────────────────
# Set this to your Vercel deployment URL (available after first Vercel deploy)
APP_BASE_URL=https://CHANGE_ME.vercel.app

# ── Outbound email ─────────────────────────────────────────────────────────
# For staging: use Mailtrap (mailtrap.io free) or skip (leave blank to disable)
EMAIL_FROM=it-support@lotris.io
EMAIL_HOST=smtp.mailtrap.io
EMAIL_PORT=587
EMAIL_USER=CHANGE_ME
EMAIL_PASS=CHANGE_ME
EMAIL_SECURE=false

# ── IMAP intake (optional — leave commented out to disable email intake) ───
# INTAKE_EMAIL_HOST=
# INTAKE_EMAIL_PORT=993
# INTAKE_EMAIL_USER=
# INTAKE_EMAIL_PASS=
# INTAKE_EMAIL_TLS=true

# ── Tenant routing (needed only if IMAP intake is enabled) ────────────────
# TRIAGE_TENANT_ID=
# TRIAGE_TEAM_ID=
# INTAKE_SYSTEM_USER_ID=

# ── Vercel only (set in Vercel dashboard, NOT in Railway) ─────────────────
# NEXT_PUBLIC_API_URL=https://api-CHANGE_ME.up.railway.app
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_CHANGE_ME
