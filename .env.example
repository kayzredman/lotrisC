# ─────────────────────────────────────────────────────────────────────────────
# Lotris — Environment Variables
# Copy this file to .env and fill in all values before running locally.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=development

# ── Databases ──────────────────────────────────────────────────────────────
# MSSQL — operational DB (tickets, users, queues, KPIs)
DATABASE_URL_MSSQL=mssql://sa:Lotris@Dev2024!@localhost:1433/lotris

# PostgreSQL — analytics DB (pre-aggregated dashboards + reports)
DATABASE_URL_POSTGRES=postgresql://lotris:lotris_dev@localhost:5432/lotris_analytics

# ── Cache & Queues ─────────────────────────────────────────────────────────
REDIS_URL=redis://:lotris_dev@localhost:6379

# ── Internal Auth (JWT) ────────────────────────────────────────────────────
# Must be ≥ 32 characters. Generate with: openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_32_CHAR_RANDOM_SECRET_AT_LEAST

# Identity provider for the C# API (login/register)
NEXT_PUBLIC_AUTH_PROVIDERS=identity

# ── Microsoft Entra (optional — customer deployments only) ───────────────
# Enables Sign in with Microsoft + Copilot OAuth. Not needed for local Lotris dev
# (use /admin/intelligence with ChatGPT/OpenAI — see docs/INTELLIGENCE-DEV-SETUP.md).
# Tenant IT: docs/INTELLIGENCE-ENTERPRISE-SETUP.md. Restart API after changing.
ENTRA_ENABLED=false
ENTRA_TENANT_ID=common
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=

# ── API Server ─────────────────────────────────────────────────────────────
API_PORT=5153
# Dev API listen address (restart-api.sh). 0.0.0.0 = phone on LAN can reach :5153
LOTRIS_API_BIND=0.0.0.0

# ── Next.js ────────────────────────────────────────────────────────────────
# Public vars — safe to expose to the browser
NEXT_PUBLIC_API_URL=http://localhost:5153

# ── Clerk Auth (deprecated — Phase 5 migrated to JWT) ──────────────────────
# CLERK_SECRET_KEY=sk_test_REPLACE_ME
# CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
# CLERK_WEBHOOK_SECRET=whsec_REPLACE_ME
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/login
# NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
# NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
