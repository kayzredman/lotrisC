# ─────────────────────────────────────────────────────────────────────────────
# Lotris — Environment Variables
# Copy this file to .env and fill in all values before running locally.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=development

# ── Databases ──────────────────────────────────────────────────────────────
# MSSQL — operational DB (tickets, users, queues, KPIs)
DATABASE_URL_MSSQL=mssql://sa:Lotris@Dev2024!@localhost:1433/lotris

# PostgreSQL — analytics DB (pre-aggregated dashboards + reports)
DATABASE_URL_POSTGRES=postgresql://lotris:lotris_dev@localhost:5432/lotris_analytics

# ── Cache & Queues ─────────────────────────────────────────────────────────
REDIS_URL=redis://:lotris_dev@localhost:6379

# ── Clerk Auth ─────────────────────────────────────────────────────────────
# Get from https://dashboard.clerk.com → your application → API Keys
CLERK_SECRET_KEY=sk_test_REPLACE_ME
CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# Clerk webhook secret — from Clerk dashboard → Webhooks → your endpoint
CLERK_WEBHOOK_SECRET=whsec_REPLACE_ME

# ── Internal Auth ──────────────────────────────────────────────────────────
# Must be ≥ 32 characters. Generate with: openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_32_CHAR_RANDOM_SECRET_AT_LEAST

# ── API Server ─────────────────────────────────────────────────────────────
API_PORT=4000

# ── Next.js ────────────────────────────────────────────────────────────────
# Public vars — safe to expose to the browser
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
NEXT_PUBLIC_API_URL=http://localhost:4000

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/login
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
