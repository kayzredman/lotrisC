{
  "name": "@lotris/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main",
    "lint": "tsc --noEmit",
    "test": "jest",
    "test:cov": "jest --coverage",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@clerk/backend": "^1.3.0",
    "@lotris/config": "workspace:*",
    "@lotris/db": "workspace:*",
    "@lotris/types": "workspace:*",
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-fastify": "^10.4.0",
    "fastify": "^4.28.1",
    "@nestjs/swagger": "^7.4.0",
    "@trpc/server": "^11.0.0",
    "bullmq": "^5.12.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "ioredis": "^5.4.0",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.9.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "svix": "^1.21.0",
    "exceljs": "^4.4.0",
    "@nestjs/platform-express": "^10.4.0",
    "multer": "^1.4.5-lts.1",
    "uuid": "^10.0.0",
    "zod": "^3.23.0",
    "pdfkit": "^0.15.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@nestjs/testing": "^10.4.0",
    "@types/jest": "^29.5.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.0",
    "@types/nodemailer": "^6.4.15",
    "@types/multer": "^1.4.12",
    "@types/uuid": "^10.0.0",
    "@types/pdfkit": "^0.13.4",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.5.0"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": { "^.+\\.(t|j)s$": "ts-jest" },
    "collectCoverageFrom": ["**/*.(t|j)s"],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
